# ── Database (Neon) ───────────────────────────────────────────────────────────
# Get from console.neon.tech → your project → Connection Details → Connection string
# Use the "Pooled connection" string for production (has -pooler in the hostname)
DATABASE_URL=postgresql://user:password@ep-xxx-xxx-pooler.region.aws.neon.tech/dbname?sslmode=require

# ── Encryption (required when using a database) ────────────────────────────────
# Any 32+ character random string. Generate one: openssl rand -hex 32
ENCRYPTION_SECRET=your_32_char_random_secret_here

# ── AI Providers ──────────────────────────────────────────────────────────────
# Gemini: free at aistudio.google.com (no credit card)
GEMINI_API_KEY=your_gemini_key_here

# Groq: free at console.groq.com (no credit card)
GROQ_API_KEY=your_groq_key_here

# Ollama: local fallback (optional — keep if you have it running)
OLLAMA_ENDPOINT=http://localhost:11434

# ── LangSmith tracing (optional — debug every LangChain call) ──────────────────
# Get a key at smith.langchain.com → Settings → API Keys. Paste it below, restart,
# and every model call + agent step is traced to your dashboard. Remove to disable.
# Project name and tracing flag are auto-set; you only need the key.
LANGSMITH_API_KEY=lsv2_your_langsmith_key_here
# LANGSMITH_PROJECT=devos   # optional — defaults to "devos"

# ── Notion ─────────────────────────────────────────────────────────────────────
# Get from notion.so/my-integrations → New integration
NOTION_API_KEY=secret_ntn_your_key_here
NOTION_TASKS_DB_ID=your_32_char_tasks_database_id
NOTION_NOTES_DB_ID=your_32_char_notes_database_id

# ── Google OAuth2 (Gmail + Calendar) ──────────────────────────────────────────
# Get from console.cloud.google.com → Credentials → OAuth 2.0 Client IDs
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your_client_secret

# ── Slack (optional — for push digest delivery) ────────────────────────────────
# Get from api.slack.com → Your Apps → OAuth & Permissions
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_USER_ID=your_slack_user_id

# ── GitHub (optional — for PR tracking) ───────────────────────────────────────
GITHUB_TOKEN=ghp_your_github_personal_access_token
GITHUB_OWNER=your_github_username
GITHUB_REPO=your_repo_name

# ── Trello (optional — for sprint board sync) ──────────────────────────────────
TRELLO_API_KEY=your_trello_api_key
TRELLO_TOKEN=your_trello_token
TRELLO_BOARD_ID=your_trello_board_id

# ── Todoist (optional — syncs new tasks to Todoist inbox) ──────────────────────
# Get your API token from todoist.com → Settings → Integrations → API token
TODOIST_API_KEY=your_todoist_api_token
